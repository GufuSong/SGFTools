// Shared SGF material helpers.

#include "/Plugin/SGFTools/Private/GeneralVFX/SequenceFrame.ush"

struct Str_SongGuFuFunLibrary_BasicGeneral
{
    float Test()
    {
        return 0.2;
    }


    // »ù´¡SampleSequenceUV
    float2 SampleSequenceUV(float InColumns, float InRows, float2 InUV, float Frame)
    {
        /*
           1. Wrap frame indices for loop playback.
           2. Keep the default path free of reverse-control logic.
        */

        float Columns = max(InColumns, 1.0);
        float Rows = max(InRows, 1.0);

        float TotalFrames = Columns * Rows;

        // Wrap the frame index into the valid range for loop playback.
        float FrameIndex = fmod(fmod(floor(Frame), TotalFrames) + TotalFrames, TotalFrames);

        float FrameX = fmod(FrameIndex, Columns);
        float FrameY = floor(FrameIndex / Columns);

        float2 CellSize = float2(1.0 / Columns, 1.0 / Rows);

        // UV inside the current cell.
        float2 LocalUV = frac(InUV);

        // Final atlas UV.
        return LocalUV * CellSize + float2(FrameX, FrameY) * CellSize;
    }

    
    // »ù´¡SampleSequenceUV  ¸½´øµ¹ÖÃUV¹¦ÄÜ
    float2 SampleSequenceUV(float InColumns, float InRows, float2 InUV, float Frame, float4 ReverseControl)
    {
        /*
           1. Wrap frame indices for loop playback.
           2. Reverse atlas frame order by columns and rows.
           3. Flip local UV inside a single frame cell.
         */

        float Columns = max(InColumns, 1.0);
        float Rows = max(InRows, 1.0);

        float TotalFrames = Columns * Rows;

        // Wrap the frame index into the valid range for loop playback.
        float FrameIndex = fmod(fmod(floor(Frame), TotalFrames) + TotalFrames, TotalFrames);

        float FrameX = fmod(FrameIndex, Columns);
        float FrameY = floor(FrameIndex / Columns);

        float2 CellSize = float2(1.0 / Columns, 1.0 / Rows);

        // UV inside the current cell.
        float2 LocalUV = frac(InUV);

        // Reverse atlas frame lookup across columns and rows.
        FrameX = lerp(FrameX, Columns - 1.0 - FrameX, step(0.5, ReverseControl.x));
        FrameY = lerp(FrameY, Rows - 1.0 - FrameY, step(0.5, ReverseControl.y));

        // Flip local UV inside the selected frame cell.
        LocalUV.x = lerp(LocalUV.x, 1.0 - LocalUV.x, step(0.5, ReverseControl.z));
        LocalUV.y = lerp(LocalUV.y, 1.0 - LocalUV.y, step(0.5, ReverseControl.w));

        // Final atlas UV.
        return LocalUV * CellSize + float2(FrameX, FrameY) * CellSize;
    }
    
    
    // »ù´¡¹âÕÕÄ£Äâ,ÎÞ¸ß¹â
    float3 SimulationLight(
        float3 WorldPosition,
        float3 Normal,
        float3 LightPosition,
        float3 LightColor,
        float LightIntensity,
        float LightRadius,
        float LightExponent,
        float Ambient)  
    {
        float3 N = normalize(Normal);

        float3 ToLight = LightPosition - WorldPosition;
        float Dist = length(ToLight);
        float3 L = ToLight / max(Dist, 0.0001);

        float NdotL = saturate(dot(N, L));

        float Range01 = saturate(1.0 - Dist / max(LightRadius, 0.0001));
        float Attenuation = pow(Range01, max(LightExponent, 0.0001));

        float LightAmount = NdotL * Attenuation * LightIntensity;

        return LightColor * (LightAmount + Ambient);
    }

    // ¹âÕÕÄ£Äâ_¸ß¹â
    float3 SimulationLight(
        float3 WorldPosition,
        float3 Normal,
        float3 LightPosition,
        float3 LightColor,
        float LightIntensity,
        float LightRadius,
        float LightExponent,
        float Ambient,
        float3 CameraPosition,
        float SpecularIntensity,
        float SpecularPower)
    {
        float3 N = normalize(Normal);

        float3 ToLight = LightPosition - WorldPosition;
        float Dist = length(ToLight);
        float3 L = ToLight / max(Dist, 0.0001);
        float3 V = normalize(CameraPosition - WorldPosition);
        float3 H = normalize(L + V);

        float NdotL = saturate(dot(N, L));
        float NdotH = saturate(dot(N, H));

        float Range01 = saturate(1.0 - Dist / max(LightRadius, 0.0001));
        float Attenuation = pow(Range01, max(LightExponent, 0.0001));

        float DiffuseAmount = NdotL * Attenuation * LightIntensity;
        float SpecularAmount = pow(NdotH, max(SpecularPower, 0.0001))
            * SpecularIntensity
            * NdotL
            * Attenuation
            * LightIntensity;

        return LightColor * (DiffuseAmount + SpecularAmount + Ambient);
    }
    
} SongGuFuFunLibrary_BasicGeneral;
